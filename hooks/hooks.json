{
  "description": "Jarvis memory system hooks - context injection, transcript capture",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js\" --server-url \"${user_config.serverUrl}\" --api-key \"${user_config.apiKey}\" --cache-dir \"${user_config.cacheDir}\" --worker-port \"${user_config.workerPort}\" --extra-headers \"${user_config.extraHeaders}\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/session-end.js\" --server-url \"${user_config.serverUrl}\" --api-key \"${user_config.apiKey}\" --extra-headers \"${user_config.extraHeaders}\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.js\" --server-url \"${user_config.serverUrl}\" --api-key \"${user_config.apiKey}\" --extra-headers \"${user_config.extraHeaders}\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
